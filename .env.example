# MCSManager panel API. API key is sent as ?apikey=...
MCSM_BASE_URL=http://127.0.0.1:23333
MCSM_API_KEY=
MCSM_DEFAULT_DAEMON_ID=
MCSM_DEFAULT_INSTANCE_UUID=
MCSM_TIMEOUT_SECONDS=10

# RCON and MSMP connection details are read per instance from MCSManager:
# - RCON: instance config fields enableRcon/rconIp/rconPort/rconPassword.
# - MSMP: server.properties management-server-* keys through MCSManager file API.
MINECRAFT_OPS_RCON_TIMEOUT_SECONDS=5
MINECRAFT_OPS_RCON_ENCODING=utf-8
MINECRAFT_OPS_MSMP_TIMEOUT_SECONDS=8
MINECRAFT_OPS_MSMP_TLS_VERIFY=true

# Set empty to disable audit logging.
MINECRAFT_OPS_AUDIT_LOG=/tmp/minecraft-ops-mcp-audit.jsonl

# Optional raw command prefix filters for server.send_command and rcon.command.
MINECRAFT_OPS_RAW_COMMAND_ALLOWLIST=
MINECRAFT_OPS_RAW_COMMAND_DENYLIST=

# Optional file-transfer guardrails.
# Empty allowlists mean "not restricted"; set them in production.
MINECRAFT_OPS_MAX_BYTES=268435456
MINECRAFT_OPS_UPLOAD_ALLOWED_DIRS=
MINECRAFT_OPS_FILE_OPERATION_WHITELIST=
MINECRAFT_OPS_UPLOAD_URL_ALLOWED_DOMAINS=

# Optional workspace for modpack snapshots and test metadata.
MINECRAFT_OPS_MODPACK_WORKSPACE=/tmp/minecraft-ops-mcp-modpacks
